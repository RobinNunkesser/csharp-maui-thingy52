<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Thingy52"
             x:DataType="local:EnvironmentViewModel"
             x:Class="Thingy52.EnvironmentPage">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding BatteryLevel}" />
    </ContentPage.ToolbarItems>
    <ContentPage.Content>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Environment"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,Auto"
                  Padding="12"
                  BackgroundColor="{AppThemeBinding Light=#F4F5F7, Dark=#1E1E1E}">
                <Label Grid.Column="0"
                       Text="Battery Level"
                       FontAttributes="Bold" />
                <Label Grid.Column="1"
                       Text="{Binding BatteryLevel}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto"
                  Padding="12"
                  BackgroundColor="{AppThemeBinding Light=#F4F5F7, Dark=#1E1E1E}">
                <Label Grid.Column="0"
                       Text="Temperature"
                       FontAttributes="Bold" />
                <Label Grid.Column="1"
                       Text="{Binding Temperature}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto"
                  Padding="12"
                  BackgroundColor="{AppThemeBinding Light=#F4F5F7, Dark=#1E1E1E}">
                <Label Grid.Column="0"
                       Text="Humidity"
                       FontAttributes="Bold" />
                <Label Grid.Column="1"
                       Text="{Binding Humidity}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto"
                  Padding="12"
                  BackgroundColor="{AppThemeBinding Light=#F4F5F7, Dark=#1E1E1E}">
                <Label Grid.Column="0"
                       Text="Pressure"
                       FontAttributes="Bold" />
                <Label Grid.Column="1"
                       Text="{Binding Pressure}" />
            </Grid>
        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>