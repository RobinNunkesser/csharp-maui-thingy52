<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Thingy52"
             xmlns:ble="clr-namespace:Thingy52.Ble.Abstractions;assembly=Thingy52.Ble.Abstractions"
             x:DataType="local:BleServicesViewModel"
             x:Class="Thingy52.BleServicesPage"
             Title="BLE Services">
    <ContentPage.Content>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="BLE Services"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusText}"
                   FontSize="13"
                   TextColor="Gray" />

            <Button Text="Aktualisieren"
                    Command="{Binding RefreshCommand}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HeightRequest="24"
                               WidthRequest="24" />

            <CollectionView ItemsSource="{Binding Services}"
                            VerticalOptions="FillAndExpand">
                <CollectionView.EmptyView>
                    <Label Text="Keine Services verfuegbar."
                           HorizontalTextAlignment="Center"
                           TextColor="Gray" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="ble:BleServiceInfo">
                        <Border Margin="0,4"
                                Stroke="#E1E1E1"
                                StrokeThickness="1"
                                Padding="12,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       IsVisible="{Binding HasDisplayName}"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding ServiceUuid}"
                                       FontSize="11"
                                       TextColor="Gray"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text=">"
                                       FontSize="16"
                                       TextColor="#9A9A9A"
                                       VerticalTextAlignment="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type local:BleServicesViewModel}}, Path=SelectServiceCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>
