<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Thingy52"
             x:DataType="local:BleCharacteristicDetailViewModel"
             x:Class="Thingy52.BleCharacteristicDetailPage"
             Title="Characteristic">
    <ContentPage.Content>
              <ScrollView>
                     <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Characteristic"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding CharInfo.CharacteristicUuid, FallbackValue='-'}"
                   FontSize="13"
                   TextColor="Gray" />

            <Label Text="{Binding CharInfo.PropertiesText, FallbackValue=''}"
                   FontSize="12"
                   TextColor="Gray" />

            <Label Text="{Binding LastEvent, StringFormat='Letztes Event: {0}'}"
                   FontSize="12"
                   TextColor="Gray" />

            <Label Text="{Binding LastValueTime, StringFormat='Zeit: {0}'}"
                   FontSize="12"
                   TextColor="Gray" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HeightRequest="24"
                               WidthRequest="24" />

            <Label Text="Wert:"
                   FontAttributes="Bold"
                   FontSize="14" />

            <Label Text="{Binding ValueText}"
                   FontSize="13"
                   FontFamily="Courier"
                   TextColor="DarkBlue" />

            <Border StrokeThickness="1"
                    Stroke="#D9D9D9"
                    Padding="12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Decoder"
                           FontAttributes="Bold"
                           FontSize="14" />
                    <Label Text="{Binding AsciiValue, StringFormat='ASCII: {0}'}"
                           FontSize="12" />
                    <Label Text="{Binding Utf8Value, StringFormat='UTF-8: {0}'}"
                           FontSize="12" />
                    <Label Text="{Binding UInt16Value, StringFormat='UInt16 LE: {0}'}"
                           FontSize="12" />
                    <Label Text="{Binding FloatValue, StringFormat='Float32 LE: {0}'}"
                           FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Lesen"
                        Command="{Binding ReadCommand}"
                        IsVisible="{Binding CharInfo.CanRead, FallbackValue=False}" />

                            <Button Text="Schreiben"
                                          Command="{Binding WriteCommand}"
                                          IsVisible="{Binding CharInfo.CanWrite, FallbackValue=False}" />

                <Button Text="{Binding SubscribeButtonText}"
                        Command="{Binding ToggleNotifyCommand}"
                        IsVisible="{Binding CharInfo.CanNotify, FallbackValue=False}" />
            </HorizontalStackLayout>

            <Entry Text="{Binding WriteValue}"
                   Placeholder="Hex (z.B. 0A FF) oder UTF-8"
                   IsVisible="{Binding CharInfo.CanWrite, FallbackValue=False}" />

            <HorizontalStackLayout Spacing="8"
                                   IsVisible="{Binding CharInfo.CanWrite, FallbackValue=False}">
                <Label Text="UTF-8 schreiben"
                       VerticalTextAlignment="Center" />
                <Switch IsToggled="{Binding WriteAsUtf8}" />
            </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>
