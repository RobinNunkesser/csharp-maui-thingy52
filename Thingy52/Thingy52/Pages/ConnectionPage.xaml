<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          xmlns:local="clr-namespace:Thingy52"
          x:DataType="local:ConnectionViewModel"
             x:Class="Thingy52.ConnectionPage">
    <ContentPage.Content>
     <VerticalStackLayout Padding="24" Spacing="16">
         <Label Text="Thingy Verbindung"
             FontSize="24"
             FontAttributes="Bold" />

         <Label Text="{Binding StatusText}"
             FontSize="16" />

         <Label Text="{Binding ConnectedDeviceText}"
             FontSize="14"
             TextColor="Gray" />

         <ActivityIndicator IsRunning="{Binding IsScanning}"
                   IsVisible="{Binding IsScanning}"
                   HeightRequest="32"
                   WidthRequest="32" />

         <Button Text="Erneut scannen"
              Command="{Binding RetryScanCommand}" />
     </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>