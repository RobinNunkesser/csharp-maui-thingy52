<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Thingy52.UIPage">
    <ContentPage.Content>
     <VerticalStackLayout Padding="20"
                 Spacing="14">
         <Label Text="UI"
             FontSize="24"
             FontAttributes="Bold" />

         <Label Text="Direkter Einstieg in den Thingy UI-Service (z.B. LED/Button Characteristics)."
             FontSize="13"
             TextColor="Gray" />

         <Button Text="UI-Service oeffnen"
              Clicked="OpenUiServiceClicked" />
     </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>