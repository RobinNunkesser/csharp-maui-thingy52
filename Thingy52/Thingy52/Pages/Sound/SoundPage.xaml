<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Thingy52.SoundPage">
    <ContentPage.Content>
     <VerticalStackLayout Padding="20"
                 Spacing="14">
         <Label Text="Sound"
             FontSize="24"
             FontAttributes="Bold" />

         <Label Text="Direkter Einstieg in den Sound-Service (Speaker/Microphone Characteristics)."
             FontSize="13"
             TextColor="Gray" />

         <Button Text="Sound-Service oeffnen"
              Clicked="OpenSoundServiceClicked" />
     </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>